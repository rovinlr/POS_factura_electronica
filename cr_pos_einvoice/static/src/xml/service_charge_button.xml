<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="cr_pos_einvoice.ServiceChargeControlButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <button
                class="control-button"
                t-att-class="{'highlight': (this.pos?.get_order?.() || this.currentOrder)?.hasServiceCharge10?.()}"
                t-on-click.stop.prevent="() => (this.pos?.get_order?.() || this.currentOrder)?.toggleServiceCharge10?.()"
                t-att-title="(this.pos?.get_order?.() || this.currentOrder)?.hasServiceCharge10?.() ? 'Quitar impuesto de servicio 10%' : 'Aplicar impuesto de servicio 10%'"
            >
                <i class="fa fa-percent me-1" role="img" aria-label="Servicio"/>
                <span t-esc="(this.pos?.get_order?.() || this.currentOrder)?.hasServiceCharge10?.() ? 'Servicio 10%: ON' : 'Servicio 10%: OFF'"/>
            </button>
        </xpath>
    </t>
</templates>
