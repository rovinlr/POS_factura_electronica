<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="cr_pos_einvoice.ServiceChargeControlButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <button
                class="control-button"
                t-on-click="onClickServiceCharge"
                t-att-title="isServiceChargeActive ? 'Quitar impuesto de servicio 10%' : 'Aplicar impuesto de servicio 10%'"
            >
                <i class="fa fa-percent me-1" role="img" aria-label="Servicio"/>
                <span t-esc="isServiceChargeActive ? 'Servicio 10%: ON' : 'Servicio 10%: OFF'"/>
            </button>
        </xpath>
    </t>
</templates>
