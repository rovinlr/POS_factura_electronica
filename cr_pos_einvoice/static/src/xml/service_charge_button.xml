<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="cr_pos_einvoice.ServiceChargeControlButton" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <button
                class="control-button"
                t-att-class="{'highlight': this.isServiceCharge10Active}"
                t-on-click.stop.prevent="onClickServiceCharge10"
                t-att-title="this.serviceChargeButtonTitle"
            >
                <i class="fa fa-percent me-1" role="img" aria-label="Servicio"/>
                <span t-esc="this.serviceChargeButtonLabel"/>
            </button>
        </xpath>
    </t>
</templates>
