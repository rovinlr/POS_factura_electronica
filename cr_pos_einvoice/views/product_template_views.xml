<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_inherit_cr_other_charge_line" model="ir.ui.view">
        <field name="name">product.template.form.inherit.cr.other.charge.line</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='point_of_sale']//group[1]" position="inside">
                <div class="o_row">
                    <field name="cr_is_other_charge_line" class="oe_inline" nolabel="1"/>
                    <label for="cr_is_other_charge_line" string="Otros cargos FE" class="oe_inline"/>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
