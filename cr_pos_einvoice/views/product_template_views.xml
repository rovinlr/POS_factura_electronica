<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_inherit_cr_other_charge_line" model="ir.ui.view">
        <field name="name">product.template.form.inherit.cr.other.charge.line</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!--
            Place the FE flag in General Information to keep UX consistent and
            avoid positional/header-level insertion that can surface the field
            outside the intended tab in newer Odoo layouts.
            -->
            <xpath expr="//page[@name='general_information']//field[@name='categ_id']" position="after">
                <field name="cr_is_other_charge_line"/>
            </xpath>
        </field>
    </record>
</odoo>
