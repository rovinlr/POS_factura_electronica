<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pos_config_form_cr_einvoice" model="ir.ui.view">
        <field name="name">pos.config.form.cr.einvoice</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                                <group string="Factura electrónica (CR)">
                    <field name="cr_fe_enabled"/>
                    <field name="cr_fe_to_invoice_emits_fe" invisible="not cr_fe_enabled"/>
                    <field name="cr_fe_auto_send_on_reference" invisible="not cr_fe_enabled"/>
                    <field name="cr_fe_auto_email_accepted_docs" invisible="not cr_fe_enabled"/>
                    <field name="cr_fe_auto_email_include_fe" invisible="not cr_fe_enabled or not cr_fe_auto_email_accepted_docs"/>
                    <field name="fp_economic_activity_id"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
