<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cr_pos_order_send_email_wizard_form" model="ir.ui.view">
        <field name="name">cr.pos.order.send.email.wizard.form</field>
        <field name="model">cr.pos.order.send.email.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar comprobante por correo">
                <group>
                    <field name="order_id"/>
                </group>
                <group>
                    <field name="email_to"/>
                    <field name="email_cc"/>
                    <field name="email_bcc"/>
                    <field name="subject"/>
                </group>
                <group>
                    <field name="body_html" nolabel="1" colspan="2"/>
                </group>
                <group string="Adjuntos">
                    <field name="attachment_ids" widget="many2many_binary"/>
                </group>
                <footer>
                    <button name="action_send" type="object" string="Enviar" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
