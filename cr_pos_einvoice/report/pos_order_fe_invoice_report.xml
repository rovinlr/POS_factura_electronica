<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_pos_order_fe_invoice" model="ir.actions.report">
        <field name="name">POS Factura Electrónica (PDF)</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_pos_einvoice.report_pos_order_fe_invoice</field>
        <field name="report_file">cr_pos_einvoice.report_pos_order_fe_invoice</field>
        <field name="print_report_name">'FE_%s' % (object.cr_fe_consecutivo or object.name or object.pos_reference or object.id)</field>
    </record>

    <template id="report_pos_order_fe_invoice">
        <t t-foreach="docs" t-as="doc">
            <t t-set="lang" t-value="doc.partner_id.lang or doc.env.lang"/>
            <t t-set="docs" t-value="doc.cr_get_virtual_move_for_fe_report()"/>
            <t t-call="account.report_invoice_document" t-lang="lang"/>
        </t>
    </template>
</odoo>
