<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="paperformat_pos_ticket_pdf" model="report.paperformat">
        <field name="name">POS Ticket CR 80mm</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">80</field>
        <field name="page_height">297</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">2</field>
        <field name="margin_bottom">2</field>
        <field name="margin_left">2</field>
        <field name="margin_right">2</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">203</field>
    </record>

    <record id="action_report_pos_order_ticket_cr" model="ir.actions.report">
        <field name="name">POS Ticket CR</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_pos_einvoice.report_pos_order_ticket_cr</field>
        <field name="report_file">cr_pos_einvoice.report_pos_order_ticket_cr</field>
        <field name="paperformat_id" ref="cr_pos_einvoice.paperformat_pos_ticket_pdf"/>
        <field name="print_report_name">'Ticket_%s' % (object.name or object.pos_reference or object.id)</field>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pos_order_ticket_cr">
        <t t-call="web.html_container">
            <style type="text/css">
                @page {
                    margin: 2mm;
                }

                .cr-pos-ticket-page,
                .cr-pos-ticket-page * {
                    box-sizing: border-box;
                    color: #000;
                    font-family: 'DejaVu Sans', Arial, sans-serif;
                }

                .cr-pos-ticket-page {
                    width: 100%;
                    max-width: none;
                    margin: 0;
                    padding: 1.5mm 1.5mm;
                    font-size: 11px;
                    line-height: 1.2;
                    background: #fff;
                }

                .cr-ticket-center {
                    text-align: center;
                }

                .cr-ticket-title {
                    margin: 0;
                    font-size: 13px;
                    font-weight: 700;
                    line-height: 1.2;
                }

                .cr-ticket-block {
                    margin-top: 2.4mm;
                }

                .cr-ticket-line {
                    margin: 0 !important;
                    padding: 0 !important;
                    line-height: 1.2;
                }

                .cr-ticket-label {
                    font-weight: 700 !important;
                }

                .cr-ticket-block .cr-ticket-line + .cr-ticket-line,
                .cr-ticket-center .cr-ticket-line + .cr-ticket-line {
                    margin-top: 0.35mm !important;
                }

                .cr-ticket-lines,
                .cr-ticket-totals {
                    width: 100%;
                    border-collapse: collapse;
                    table-layout: auto;
                }

                .cr-ticket-lines {
                    margin-top: 2.2mm;
                }

                .cr-ticket-lines col.qty {
                    width: 14%;
                }

                .cr-ticket-lines col.desc {
                    width: 54%;
                }

                .cr-ticket-lines col.amt {
                    width: 32%;
                }

                .cr-ticket-lines thead th {
                    border-top: 1px solid #000;
                    border-bottom: 1px solid #000;
                    font-size: 11px;
                    font-weight: 700;
                    padding: 0.7mm 0.7mm;
                }

                .cr-ticket-lines thead th:first-child {
                    border-left: 1px solid #000;
                }

                .cr-ticket-lines thead th:last-child {
                    border-right: 1px solid #000;
                }

                .cr-ticket-lines td {
                    padding: 0.45mm 0.7mm;
                    vertical-align: top;
                    overflow-wrap: break-word;
                    word-break: break-word;
                }

                .txt-left {
                    text-align: left;
                    padding-left: 1mm;
                }

                .txt-right {
                    text-align: right;
                    white-space: nowrap;
                }

                .cr-ticket-totals {
                    margin-top: 2mm;
                    width: 56%;
                    margin-left: auto;
                }

                .cr-ticket-totals td {
                    padding: 0.8mm 0;
                }

                .cr-ticket-totals .label {
                    width: 52%;
                    text-align: left;
                    font-weight: 500;
                }

                .cr-ticket-totals .amount {
                    width: 42%;
                    text-align: right;
                    white-space: nowrap;
                }

                .cr-ticket-totals .final td {
                    border-top: 1px solid #000;
                    font-weight: 700;
                    font-size: 13px;
                    padding-top: 1.4mm;
                }

                .cr-ticket-footer {
                    margin-top: 2.2mm;
                    border-top: 1px solid #000;
                    padding-top: 1mm;
                    word-break: break-all;
                }

                .cr-ticket-small {
                    font-size: 10px;
                    line-height: 1.2;
                }
            </style>

            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page cr-pos-ticket-page" style="padding:1.5mm 1.5mm; width:100%; margin:0; font-size:11px; line-height:1.2;">
                        <t t-set="doc_type_map" t-value="{'te': 'Tiquete electrónico', 'fe': 'Factura electrónica', 'nc': 'Nota de crédito electrónica', 'nd': 'Nota de débito electrónica'}"/>
                        <t t-set="doc_type_label" t-value="doc_type_map.get(o.cr_fe_document_type or 'te', 'Comprobante electrónico')"/>
                        <t t-set="company_phone" t-value="o.company_id.phone or (o.company_id.partner_id and o.company_id.partner_id.phone)"/>
                        <t t-set="company_email" t-value="o.company_id.email or (o.company_id.partner_id and o.company_id.partner_id.email)"/>
                        <t t-set="company_address" t-value="o.company_id.partner_id and o.company_id.partner_id._display_address(without_company=True)"/>
                        <t t-set="partner_address" t-value="o.partner_id and o.partner_id._display_address(without_company=True)"/>
                        <t t-set="partner_phone" t-value="o._cr_get_partner_phone(o.partner_id)"/>

                        <div class="cr-ticket-center" style="text-align:center; line-height:1.28;">
                            <h4 class="cr-ticket-title" style="margin:0; font-size:12px; font-weight:700; line-height:1.2; white-space:normal; word-break:break-word;">
                                <span t-esc="o.company_id.name"/>
                            </h4>
                            <p class="cr-ticket-line" t-if="o.company_id.vat" style="margin:0; padding:0;">
                                <span class="cr-ticket-label" style="font-weight:700;">Identificación: </span><span t-esc="o.company_id.vat"/>
                            </p>
                            <p class="cr-ticket-line" t-if="company_email" style="margin:0; padding:0;">
                                <span class="cr-ticket-label" style="font-weight:700;">Correo: </span><span t-esc="company_email"/>
                            </p>
                            <p class="cr-ticket-line" t-if="company_phone" style="margin:0; padding:0;">
                                <span class="cr-ticket-label" style="font-weight:700;">Teléfono: </span><span t-esc="company_phone"/>
                            </p>
                            <p class="cr-ticket-line" t-if="company_address" style="margin:0; padding:0;">
                                <span class="cr-ticket-label" style="font-weight:700;">Dirección: </span><span t-esc="(company_address or '').replace('\n', ' ').strip()"/>
                            </p>
                        </div>

                        <div class="cr-ticket-block" style="margin-top:2mm; line-height:1.28;">
                            <p class="cr-ticket-line" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Documento: </span><span t-esc="doc_type_label"/></p>
                            <p class="cr-ticket-line" t-if="o.cr_fe_consecutivo" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Consecutivo: </span><span t-esc="o.cr_fe_consecutivo"/></p>
                            <p class="cr-ticket-line" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Orden: </span><span t-esc="o.name or o.pos_reference"/></p>
                            <p class="cr-ticket-line" t-if="o.date_order" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Fecha: </span><span t-field="o.date_order" t-options='{"widget": "datetime"}'/></p>
                        </div>

                        <div class="cr-ticket-block" style="margin-top:2mm; line-height:1.28;">
                            <p class="cr-ticket-line cr-ticket-label" style="margin:0; padding:0; font-weight:700;">Datos del cliente</p>
                            <p class="cr-ticket-line" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Nombre: </span><span t-esc="o.partner_id.display_name if o.partner_id else 'Consumidor Final'"/></p>
                            <p class="cr-ticket-line" t-if="o.partner_id and o.partner_id.vat" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Identificación: </span><span t-esc="o.partner_id.vat"/></p>
                            <p class="cr-ticket-line" t-if="partner_phone" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Teléfono: </span><span t-esc="partner_phone"/></p>
                            <p class="cr-ticket-line" t-if="o.partner_id and o.partner_id.email" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Correo: </span><span t-esc="o.partner_id.email"/></p>
                            <p class="cr-ticket-line" t-if="partner_address" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Dirección: </span><span t-esc="(partner_address or '').replace('\n', ' ').strip()"/></p>
                            <div style="height:1.2mm;"></div>
                        </div>

                        <table class="cr-ticket-lines" aria-label="Detalle de productos" style="width:100%; border-collapse:collapse; table-layout:auto;">
                            <colgroup>
                                <col class="qty"/>
                                <col class="desc"/>
                                <col class="amt"/>
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="txt-right" style="text-align:right;">Cant.</th>
                                    <th class="txt-left" style="text-align:left; padding-left:1mm;">Producto</th>
                                    <th class="txt-right" style="text-align:right;">Importe</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.lines" t-as="line">
                                    <t t-set="line_tax_percent" t-value="sum(line.tax_ids_after_fiscal_position.mapped('amount')) if line.tax_ids_after_fiscal_position else 0.0"/>
                                    <td class="txt-right" style="text-align:right;"><span t-esc="line.qty"/></td>
                                    <td class="txt-left" style="text-align:left; padding-left:1mm;"><span t-esc="line.full_product_name or line.product_id.display_name"/></td>
                                    <td class="txt-right" style="text-align:right; white-space:nowrap;">
                                        <span t-esc="line.price_subtotal_incl" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                                        <span style="padding-left:1mm;" t-esc="'{}%'.format('{:g}'.format(line_tax_percent))"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-set="other_charges_amount" t-value="o.cr_other_charges_amount or 0.0"/>
                        <t t-set="subtotal_amount" t-value="o.amount_total - o.amount_tax - other_charges_amount"/>

                        <div style="height:1.2mm;"></div>
                        <table class="cr-ticket-totals" aria-label="Totales" style="width:100%; border-collapse:collapse;">
                            <tbody>
                                <tr>
                                    <td class="label" style="text-align:left;">Subtotal</td>
                                    <td class="amount" style="text-align:right; white-space:nowrap;"><span t-esc="subtotal_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr>
                                    <td class="label" style="text-align:left;">Impuesto</td>
                                    <td class="amount" style="text-align:right; white-space:nowrap;"><span t-esc="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr t-if="other_charges_amount">
                                    <td class="label" style="text-align:left;">Servicio 10%</td>
                                    <td class="amount" style="text-align:right; white-space:nowrap;"><span t-esc="other_charges_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr class="final">
                                    <td class="label" style="text-align:left; font-weight:700;">Total</td>
                                    <td class="amount" style="text-align:right; white-space:nowrap; font-weight:700;"><span t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>
                        <div style="height:1.2mm;"></div>

                        <div t-if="other_charges_amount" class="cr-ticket-block" style="margin-top:0.8mm; line-height:1.25;">
                            <p class="cr-ticket-line" style="margin:0; padding:0;">
                                <span class="cr-ticket-label" style="font-weight:700;">Otros cargos: </span>
                                <span t-esc="other_charges_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
                            </p>
                        </div>

                        <div t-if="o.cr_fe_clave" class="cr-ticket-footer">
                            <p class="cr-ticket-line" style="margin:0; padding:0;"><span class="cr-ticket-label" style="font-weight:700;">Clave: </span><span t-esc="o.cr_fe_clave"/></p>
                            <div class="cr-ticket-small">
                                <div>Autorizado mediante la resolución MH-DGT-RES-0027-2024 del 19/11/2024</div>
                                <div>Versión XML 4.4</div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
