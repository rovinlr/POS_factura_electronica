<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="paperformat_pos_ticket_pdf" model="report.paperformat">
        <field name="name">POS Ticket CR A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">8</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">203</field>
    </record>

    <record id="action_report_pos_order_ticket_cr" model="ir.actions.report">
        <field name="name">POS Ticket CR</field>
        <field name="model">pos.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cr_pos_einvoice.report_pos_order_ticket_cr</field>
        <field name="report_file">cr_pos_einvoice.report_pos_order_ticket_cr</field>
        <field name="paperformat_id" ref="cr_pos_einvoice.paperformat_pos_ticket_pdf"/>
        <field name="print_report_name">'Ticket_%s' % (object.name or object.pos_reference or object.id)</field>
        <field name="binding_model_id" ref="point_of_sale.model_pos_order"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_pos_order_ticket_cr">
        <t t-call="web.html_container">
            <style type="text/css">
                .article.o_report_layout_standard,
                .article.o_report_layout_striped,
                .o_report_layout_standard,
                .o_report_layout_striped {
                    padding: 0 !important;
                    margin: 0 !important;
                }

                .cr-pos-ticket-page,
                .cr-pos-ticket-page * {
                    box-sizing: border-box;
                    color: #000;
                    font-family: 'DejaVu Sans', Arial, sans-serif;
                }

                .cr-pos-ticket-page {
                    width: 100%;
                    max-width: 680px;
                    margin: 0 auto;
                    padding: 8mm 10mm;
                    border: 1px solid #d9d9d9;
                    border-radius: 4px;
                    font-size: 12px;
                    line-height: 1.35;
                    background: #fff;
                }

                .cr-ticket-center {
                    text-align: center;
                }

                .cr-ticket-title {
                    margin: 0;
                    font-size: 13px;
                    font-weight: 700;
                    line-height: 1.2;
                }

                .cr-ticket-block {
                    margin-top: 4mm;
                }

                .cr-ticket-line {
                    margin: 0;
                    padding: 0;
                }

                .cr-ticket-label {
                    font-weight: 700;
                }

                .cr-ticket-lines,
                .cr-ticket-totals {
                    width: 100%;
                    border-collapse: collapse;
                    table-layout: fixed;
                }

                .cr-ticket-lines {
                    margin-top: 4mm;
                }

                .cr-ticket-lines col.qty {
                    width: 12%;
                }

                .cr-ticket-lines col.desc {
                    width: 60%;
                }

                .cr-ticket-lines col.amt {
                    width: 28%;
                }

                .cr-ticket-lines thead th {
                    border-bottom: 1px solid #000;
                    font-size: 12px;
                    font-weight: 700;
                    padding: 1.2mm 0;
                }

                .cr-ticket-lines td {
                    padding: 1mm 0;
                    vertical-align: top;
                    overflow-wrap: break-word;
                    word-break: break-word;
                }

                .txt-left {
                    text-align: left;
                    padding-left: 1mm;
                }

                .txt-right {
                    text-align: right;
                    white-space: nowrap;
                }

                .cr-ticket-totals {
                    margin-top: 4mm;
                }

                .cr-ticket-totals td {
                    padding: 0.8mm 0;
                }

                .cr-ticket-totals .label {
                    width: 64%;
                    text-align: right;
                    font-weight: 700;
                }

                .cr-ticket-totals .amount {
                    width: 36%;
                    text-align: right;
                    white-space: nowrap;
                }

                .cr-ticket-totals .final td {
                    border-top: 1px solid #000;
                    font-weight: 700;
                    font-size: 13px;
                    padding-top: 1.4mm;
                }

                .cr-ticket-footer {
                    margin-top: 4mm;
                    border-top: 1px solid #000;
                    padding-top: 1.4mm;
                    word-break: break-all;
                }

                .cr-ticket-small {
                    font-size: 10px;
                    line-height: 1.2;
                }
            </style>

            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page cr-pos-ticket-page">
                        <t t-set="doc_type_map" t-value="{'te': 'Tiquete electrónico', 'fe': 'Factura electrónica', 'nc': 'Nota de crédito electrónica', 'nd': 'Nota de débito electrónica'}"/>
                        <t t-set="doc_type_label" t-value="doc_type_map.get(o.cr_fe_document_type or 'te', 'Comprobante electrónico')"/>
                        <t t-set="company_phone" t-value="o.company_id.phone or (o.company_id.partner_id and o.company_id.partner_id.phone)"/>
                        <t t-set="company_email" t-value="o.company_id.email or (o.company_id.partner_id and o.company_id.partner_id.email)"/>
                        <t t-set="company_address" t-value="o.company_id.partner_id and o.company_id.partner_id._display_address(without_company=True)"/>
                        <t t-set="partner_address" t-value="o.partner_id and o.partner_id._display_address(without_company=True)"/>
                        <t t-set="partner_phone" t-value="o._cr_get_partner_phone(o.partner_id)"/>

                        <div class="cr-ticket-center">
                            <h4 class="cr-ticket-title"><span t-esc="o.company_id.name"/></h4>
                            <p class="cr-ticket-line" t-if="o.company_id.vat"><span class="cr-ticket-label">Identificación: </span><span t-esc="o.company_id.vat"/></p>
                            <p class="cr-ticket-line" t-if="company_email"><span class="cr-ticket-label">Correo: </span><span t-esc="company_email"/></p>
                            <p class="cr-ticket-line" t-if="company_phone"><span class="cr-ticket-label">Teléfono: </span><span t-esc="company_phone"/></p>
                            <p class="cr-ticket-line" t-if="company_address"><span class="cr-ticket-label">Dirección: </span><span t-esc="(company_address or '').replace('\n', ' ').strip()"/></p>
                        </div>

                        <div class="cr-ticket-block">
                            <p class="cr-ticket-line"><span class="cr-ticket-label">Documento: </span><span t-esc="doc_type_label"/></p>
                            <p class="cr-ticket-line" t-if="o.cr_fe_consecutivo"><span class="cr-ticket-label">Consecutivo: </span><span t-esc="o.cr_fe_consecutivo"/></p>
                            <p class="cr-ticket-line"><span class="cr-ticket-label">Orden: </span><span t-esc="o.name or o.pos_reference"/></p>
                            <p class="cr-ticket-line" t-if="o.date_order"><span class="cr-ticket-label">Fecha: </span><span t-field="o.date_order" t-options='{"widget": "datetime"}'/></p>
                        </div>

                        <div class="cr-ticket-block">
                            <p class="cr-ticket-line cr-ticket-label">Datos del cliente</p>
                            <p class="cr-ticket-line"><span class="cr-ticket-label">Nombre: </span><span t-esc="o.partner_id.display_name if o.partner_id else 'Consumidor Final'"/></p>
                            <p class="cr-ticket-line" t-if="o.partner_id and o.partner_id.vat"><span class="cr-ticket-label">Identificación: </span><span t-esc="o.partner_id.vat"/></p>
                            <p class="cr-ticket-line" t-if="partner_phone"><span class="cr-ticket-label">Teléfono: </span><span t-esc="partner_phone"/></p>
                            <p class="cr-ticket-line" t-if="o.partner_id and o.partner_id.email"><span class="cr-ticket-label">Correo: </span><span t-esc="o.partner_id.email"/></p>
                            <p class="cr-ticket-line" t-if="partner_address"><span class="cr-ticket-label">Dirección: </span><span t-esc="(partner_address or '').replace('\n', ' ').strip()"/></p>
                        </div>

                        <table class="cr-ticket-lines" aria-label="Detalle de productos">
                            <colgroup>
                                <col class="qty"/>
                                <col class="desc"/>
                                <col class="amt"/>
                            </colgroup>
                            <thead>
                                <tr>
                                    <th class="txt-right">Cant</th>
                                    <th class="txt-left">Descripción</th>
                                    <th class="txt-right">Importe</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="o.lines" t-as="line">
                                    <td class="txt-right"><span t-esc="line.qty"/></td>
                                    <td class="txt-left"><span t-esc="line.full_product_name or line.product_id.display_name"/></td>
                                    <td class="txt-right"><span t-esc="line.price_subtotal" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <t t-set="other_charges_amount" t-value="o.cr_other_charges_amount or 0.0"/>
                        <t t-set="subtotal_amount" t-value="o.amount_total - o.amount_tax - other_charges_amount"/>

                        <table class="cr-ticket-totals" aria-label="Totales">
                            <tbody>
                                <tr>
                                    <td class="label">Subtotal</td>
                                    <td class="amount"><span t-esc="subtotal_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr>
                                    <td class="label">Impuesto</td>
                                    <td class="amount"><span t-esc="o.amount_tax" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr t-if="other_charges_amount">
                                    <td class="label">Servicio 10%</td>
                                    <td class="amount"><span t-esc="other_charges_amount" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                                <tr class="final">
                                    <td class="label">Total</td>
                                    <td class="amount"><span t-esc="o.amount_total" t-options='{"widget": "monetary", "display_currency": o.currency_id}'/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div t-if="o.cr_fe_clave" class="cr-ticket-footer">
                            <p class="cr-ticket-line"><span class="cr-ticket-label">Clave: </span><span t-esc="o.cr_fe_clave"/></p>
                            <div class="cr-ticket-small">
                                <div>Autorizado mediante la resolución MH-DGT-RES-0027-2024 del 19/11/2024</div>
                                <div>Versión XML 4.4</div>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
